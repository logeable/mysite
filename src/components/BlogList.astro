---
import type { DataEntryMap } from "astro:content";
import { getBlogUrl } from "../utils/blog";

type BlogEntry = DataEntryMap["blog"][string];
type Props = {
  blogs: BlogEntry[];
  featuredBlog?: BlogEntry;
};

const { blogs, featuredBlog } = Astro.props;

const formatDate = (date: Date) => {
  return date.toLocaleDateString("zh-CN");
};

const formatDateParts = (date: Date) => {
  const [year, month, day] = date.toISOString().slice(0, 10).split("-");
  return { year, month, day };
};
---

<div class="container">
  {
    featuredBlog && (
      <article class="featured-post">
        <div class="featured-date-block" aria-hidden="true">
          <span class="month">{formatDateParts(featuredBlog.data.publishDate).month}</span>
          <span class="day">{formatDateParts(featuredBlog.data.publishDate).day}</span>
          <span class="year">{formatDateParts(featuredBlog.data.publishDate).year}</span>
        </div>
        <div class="featured-header">
          <div class="featured-rule" aria-hidden="true"></div>
        </div>
        <h2 class="featured-title">
          <a href={getBlogUrl(featuredBlog)}>{featuredBlog.data.title}</a>
        </h2>
        <p class="featured-description">{featuredBlog.data.description}</p>
        <div class="featured-footer">
          <div class="tags" aria-label="文章标签">
            {featuredBlog.data.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
            {featuredBlog.data.isAI && <span class="ai-mark">AI</span>}
          </div>
        </div>
      </article>
    )
  }

  <section class="recent-posts" aria-labelledby="recent-posts-title">
    <div class="recent-header">
      <h2 id="recent-posts-title">Blogs</h2>
    </div>

    <ul>
      {
        blogs.map((blog: BlogEntry) => (
          <li>
            <article class="post-card">
              <div class="post-date-rail" aria-hidden="true">
                <span class="month">{formatDateParts(blog.data.publishDate).month}</span>
                <span class="day">{formatDateParts(blog.data.publishDate).day}</span>
              </div>
              <div class="post-body">
                <div class="card-meta">
                  <div class="tags" aria-label="文章标签">
                    {blog.data.tags.slice(0, 2).map((tag) => <span>{tag}</span>)}
                    {blog.data.isAI && <span class="ai-mark">AI</span>}
                  </div>
                </div>
                <h3 class="title">
                  <a href={getBlogUrl(blog)}>{blog.data.title}</a>
                </h3>
                <p class="description">{blog.data.description}</p>
              </div>
            </article>
          </li>
        ))
      }
    </ul>
  </section>
</div>

<style lang="scss">
  .container {
    display: flex;
    flex-direction: column;
    gap: 2.75rem;

    .featured-post {
      position: relative;
      margin-top: 0.35rem;
      padding: 1.7rem 0 2.15rem 8rem;
      border-radius: 0;
      background: transparent;
      display: flex;
      flex-direction: column;
      gap: 1.1rem;

      .featured-date-block {
        position: absolute;
        left: 0;
        top: 1.55rem;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        line-height: 0.95;

        .month,
        .year {
          color: var(--text-color-secondary);
          font-size: 0.68rem;
          font-weight: 600;
          letter-spacing: 0.18em;
          text-transform: uppercase;
        }

        .day {
          margin: 0.18rem 0 0.08rem;
          font-size: 3.2rem;
          font-weight: 600;
          letter-spacing: -0.09em;
          color: var(--text-color);
        }
      }

      .featured-header,
      .featured-footer {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .featured-rule {
        width: 112px;
        height: 1px;
        background: color-mix(in srgb, var(--text-color) 16%, var(--border-color) 84%);
      }

      .featured-title {
        max-width: 16ch;
        font-family: Iowan Old Style, Palatino Linotype, Book Antiqua, Georgia,
          serif;
        font-size: clamp(2.2rem, 3.2vw, 3.5rem);
        line-height: 0.98;
        letter-spacing: -0.045em;

        a {
          color: var(--text-color);
          text-decoration: none;

          &:hover {
            color: color-mix(in srgb, var(--text-color) 88%, var(--primary-color) 12%);
          }
        }
      }

      .featured-description {
        max-width: 64ch;
        color: var(--text-color-secondary);
        font-size: 0.97rem;
        line-height: 1.88;
      }
    }

    .recent-posts {
      display: flex;
      flex-direction: column;
      gap: 0.9rem;

      .recent-header {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 1rem;
        flex-wrap: wrap;
        padding: 0 0.15rem;

        h2 {
          font-size: 0.76rem;
          letter-spacing: 0.18em;
          text-transform: uppercase;
          color: var(--text-color-secondary);
        }
      }

      ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
    }

    .post-card {
      display: grid;
      grid-template-columns: 68px minmax(0, 1fr);
      column-gap: 1.1rem;
      align-items: start;
      background: transparent;
      border-radius: 0;
      padding: 1.35rem 0.15rem 1.55rem;
      border-top: 1px solid
        color-mix(in srgb, var(--text-color) 8%, var(--border-color) 92%);
      transition:
        border-color 0.2s,
        transform 0.2s;

      &:hover {
        transform: translateX(3px);
        border-color: color-mix(
          in srgb,
          var(--text-color) 16%,
          var(--border-color) 84%
        );
      }
    }

    .post-date-rail {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      padding-top: 0.05rem;
      line-height: 0.95;

      .month {
        color: var(--text-color-secondary);
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .day {
        margin-top: 0.16rem;
        font-size: 1.9rem;
        font-weight: 600;
        letter-spacing: -0.08em;
        color: var(--text-color);
      }
    }

    .post-body {
      display: flex;
      flex-direction: column;
      gap: 0.72rem;
      min-width: 0;
    }

    .card-meta {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 0.8rem;
      flex-wrap: wrap;
    }

    .title {
      max-width: 24ch;
      font-family: Iowan Old Style, Palatino Linotype, Book Antiqua, Georgia,
        serif;
      font-size: clamp(1.45rem, 1.9vw, 2.05rem);
      line-height: 1.08;
      letter-spacing: -0.035em;

      a {
        text-decoration: none;
        color: var(--text-color);
        font-weight: 600;
        transition: color 0.2s;

        &:hover {
          color: color-mix(in srgb, var(--text-color) 88%, var(--primary-color) 12%);
        }
      }
    }

    .date {
      font-size: 0.88rem;
      color: var(--text-color-secondary);
      font-style: italic;
    }

    .description {
      max-width: 62ch;
      font-size: 0.93rem;
      color: var(--text-color-secondary);
      line-height: 1.8;
    }

    .tags {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      flex-wrap: wrap;

      span {
        display: inline-flex;
        align-items: center;
        min-height: 1.45rem;
        padding: 0.1rem 0;
        border-radius: 0;
        background: transparent;
        color: var(--text-color-secondary);
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .ai-mark {
        color: color-mix(in srgb, var(--text-color) 76%, var(--primary-color) 24%);
      }
    }
  }

  @media (max-width: 720px) {
    .container {
      gap: 2rem;

      .featured-post {
        padding: 1.15rem 0 1.35rem;
        padding-left: 0;

        .featured-date-block {
          position: static;
          flex-direction: row;
          align-items: baseline;
          gap: 0.45rem;

          .day {
            margin: 0;
            font-size: 1.9rem;
          }
        }

        .featured-title {
          max-width: none;
          font-size: 1.95rem;
        }

        .featured-description {
          font-size: 0.96rem;
          line-height: 1.72;
        }
      }

      .recent-posts {
        .recent-header {
          align-items: start;
        }
      }

      .post-card {
        grid-template-columns: 1fr;
        padding: 1rem 0.1rem 1.1rem;
        row-gap: 0.55rem;
      }

      .post-date-rail {
        flex-direction: row;
        align-items: baseline;
        gap: 0.35rem;

        .day {
          margin-top: 0;
          font-size: 1.15rem;
        }
      }

      .title {
        max-width: none;
        font-size: 1.22rem;
      }

      .description {
        max-width: none;
        font-size: 0.94rem;
        line-height: 1.68;
      }
    }
  }
</style>
