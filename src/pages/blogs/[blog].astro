---
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import BlogDetail from "../../components/BlogDetail.astro";
import {
  getBlogBySlug,
  getBlogUrl,
  getStaticBlogPaths,
} from "../../utils/blog";

export const getStaticPaths = (async () => {
  return getStaticBlogPaths();
}) satisfies GetStaticPaths;

const { blog: id } = Astro.params;

const blog = await getBlogBySlug(id);
if (!blog) {
  throw new Error(`Blog with id ${id} not found`);
}

const layoutProps = {
  title: blog.data.title,
  description: blog.data.description,
  publishDate: blog.data.publishDate,
  modifiedDate: blog.data.modifiedDate,
  ogImage: blog.data.ogImage,
  canonicalPath: getBlogUrl(blog),
};
---

<Layout {...layoutProps}>
  <BlogDetail blog={blog} />
</Layout>

<style></style>
