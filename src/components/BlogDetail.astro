---
import type { DataEntryMap } from "astro:content";
import { render } from "astro:content";

type Props = DataEntryMap["blog"];
const { blog } = Astro.props;

const { Content, headings } = await render(blog);
const publishedAt = blog.data.publishDate.toLocaleDateString("zh-CN");
const tocItems = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<article class="markdown-body">
  <a id="top"></a>
  <div class="blog-detail-header">
    <div class="meta-row">
      <p class="published-at">{publishedAt}</p>
      {
        blog.data.isAI && (
          <p class="ai-mark-container">
            <span class="ai-mark">AI</span>
          </p>
        )
      }
    </div>
    <h1 class="title">{blog.data.title}</h1>
    <p class="description">{blog.data.description}</p>
    {
      blog.data.tags.length > 0 && (
        <div class="tag-row" aria-label="文章标签">
          {blog.data.tags.map((tag) => <a href={`/tags/${tag}`}>{tag}</a>)}
        </div>
      )
    }
  </div>
  <div class="blog-detail-shell">
    <div class="blog-detail-content">
      <Content />
    </div>
    {
      tocItems.length > 0 && (
        <aside class="blog-detail-toc-wrap" data-toc-wrap>
          <details class="blog-detail-toc-panel" data-toc-panel open>
            <summary class="blog-detail-toc-summary">
              <span class="summary-label">On This Page</span>
              <span class="summary-meta">{tocItems.length} sections</span>
            </summary>
            <nav class="blog-detail-toc" aria-label="文章目录" data-toc-nav>
              <div class="toc-top">
                <p class="toc-label">On This Page</p>
                <a class="toc-back-top" href="#top">Top</a>
              </div>
              <ol>
                {
                  tocItems.map((item) => (
                    <li class:list={{ nested: item.depth === 3 }}>
                      <a href={`#${item.slug}`} data-toc-link={item.slug}>
                        {item.text}
                      </a>
                    </li>
                  ))
                }
              </ol>
            </nav>
          </details>
        </aside>
      )
    }
  </div>
</article>

<script>
  const initBlogToc = () => {
    const toc = document.querySelector("[data-toc-nav]");
    const wrap = document.querySelector<HTMLElement>("[data-toc-wrap]");
    const shell = document.querySelector<HTMLElement>(".blog-detail-shell");
    const panel = document.querySelector<HTMLDetailsElement>("[data-toc-panel]");
    if (!toc || !wrap || !shell || !panel) return;

    const links = Array.from(
      toc.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"),
    );
    const sections = links
      .map((link) => {
        const slug = link.dataset.tocLink;
        if (!slug) return null;

        const target = document.getElementById(slug);
        if (!target) return null;

        return { slug, link, target };
      })
      .filter((item): item is NonNullable<typeof item> => Boolean(item));

    if (sections.length === 0) return;

    let activeSlug = "";

    const setActive = (slug: string) => {
      if (activeSlug === slug) return;
      activeSlug = slug;

      for (const section of sections) {
        const isActive = section.slug === slug;
        section.link.classList.toggle("is-active", isActive);
        section.link.setAttribute("aria-current", isActive ? "true" : "false");
      }
    };

    const updateActive = () => {
      const offset = window.innerHeight * 0.2;
      let current = sections[0]?.slug ?? "";

      for (const section of sections) {
        if (section.target.getBoundingClientRect().top <= offset) {
          current = section.slug;
        } else {
          break;
        }
      }

      setActive(current);
    };

    const clearPinnedState = () => {
      toc.classList.remove("is-fixed");
      toc.style.removeProperty("left");
      toc.style.removeProperty("width");
      toc.style.removeProperty("top");
    };

    const updatePinned = () => {
      if (window.innerWidth <= 1080) {
        clearPinnedState();
        return;
      }

      const topOffset = 92;
      const minTop = 20;
      const bottomGap = 28;
      const wrapRect = wrap.getBoundingClientRect();
      const shellRect = shell.getBoundingClientRect();
      const shouldPin = wrapRect.top <= topOffset;

      if (!shouldPin) {
        clearPinnedState();
        return;
      }

      const nextTop = Math.max(
        minTop,
        Math.min(topOffset, shellRect.bottom - toc.offsetHeight - bottomGap),
      );

      toc.classList.add("is-fixed");
      toc.style.left = `${Math.round(wrapRect.left)}px`;
      toc.style.width = `${Math.round(wrapRect.width)}px`;
      toc.style.top = `${Math.round(nextTop)}px`;
    };

    const updateTocState = () => {
      panel.open = window.innerWidth > 720;
      updateActive();
      updatePinned();
    };

    toc.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (!target.closest("[data-toc-link]")) return;
      if (window.innerWidth <= 720) {
        panel.open = false;
      }
    });

    updateTocState();
    window.addEventListener("scroll", updateTocState, { passive: true });
    window.addEventListener("resize", updateTocState);
  };

  initBlogToc();
  document.addEventListener("astro:after-swap", initBlogToc);
</script>

<style lang="scss" is:global>
  .markdown-body {
    line-height: 1.75;
    color: var(--text-color);
    margin: 0 auto;
    max-width: 100%;
    word-wrap: break-word;
    overflow-wrap: break-word;
    word-break: break-word;

    .blog-detail-header {
      margin: 0 auto 2.5rem;
      max-width: 76ch;
      padding: 0.45rem 0 1.65rem;
      border-bottom: 1px solid
        color-mix(in srgb, var(--text-color) 10%, var(--border-color) 90%);
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.7rem;

      .meta-row {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .published-at {
        margin: 0;
        color: var(--text-color-secondary);
        opacity: 1;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .title {
        max-width: 18ch;
        font-family: Iowan Old Style, Palatino Linotype, Book Antiqua, Georgia,
          serif;
        font-size: clamp(2.6rem, 4.3vw, 4.3rem);
        display: block;
        margin: 0;
        letter-spacing: -0.06em;
        border: none;
        line-height: 0.95;
        color: var(--text-color);
      }

      .ai-mark-container {
        margin: 0;

        .ai-mark {
          display: inline-block;
          font-size: 0.68rem;
          padding: 0.12rem 0;
          background: transparent;
          color: color-mix(in srgb, var(--text-color) 76%, var(--primary-color) 24%);
          border-radius: 0;
          font-weight: 600;
          letter-spacing: 0.16em;
          text-transform: uppercase;
        }
      }

      .description {
        max-width: 64ch;
        margin: 0.15rem 0 0;
        color: var(--text-color-secondary);
        opacity: 1;
        font-size: 0.97rem;
        font-weight: 500;
        line-height: 1.84;
      }

      .tag-row {
        max-width: 64ch;
        display: flex;
        align-items: center;
        gap: 0.65rem 0.75rem;
        flex-wrap: wrap;
        margin-top: 0.15rem;

        a {
          display: inline-flex;
          align-items: center;
          font-size: 0.66rem;
          font-weight: 700;
          letter-spacing: 0.14em;
          text-transform: uppercase;
          color: var(--text-color-secondary);
          text-decoration: none;
          transition:
            color 0.18s ease,
            opacity 0.18s ease;

          &:hover {
            color: var(--text-color);
            text-decoration: none;
          }
        }
      }
    }

    .blog-detail-shell {
      max-width: 1140px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(0, 70ch) minmax(236px, 280px);
      column-gap: 2.8rem;
      row-gap: 0;
      align-items: start;
      justify-content: center;
    }

    .blog-detail-content {
      min-width: 0;
    }

    .blog-detail-toc-wrap {
      position: relative;
      min-width: 0;
    }

    .blog-detail-toc-panel {
      margin: 0;
      padding: 0;
      border: none;

      &[open] {
        .blog-detail-toc-summary {
          margin-bottom: 0;
        }
      }
    }

    .blog-detail-toc-summary {
      display: none;
      list-style: none;
      cursor: pointer;
      user-select: none;

      &::-webkit-details-marker {
        display: none;
      }
    }

    .blog-detail-toc {
      position: relative;
      padding: 0.85rem 0 0 1.25rem;
      border-left: 1px solid
        color-mix(in srgb, var(--text-color) 8%, var(--border-color) 92%);
      background: transparent;
      max-height: calc(100vh - 7.5rem);
      overflow-y: auto;
      overscroll-behavior: contain;
      scrollbar-width: thin;

      &.is-fixed {
        position: fixed;
        top: 5.75rem;
      }

      .toc-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.8rem;
      }

      .toc-label {
        margin: 0;
        color: var(--text-color-secondary);
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .toc-back-top {
        color: var(--text-color-secondary);
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        text-decoration: none;

        &:hover {
          color: var(--text-color);
          text-decoration: none;
        }
      }

      > ol {
        max-width: none;
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }

      > ol > li {
        margin: 0;
        padding: 0;
        line-height: 1.35;
        list-style: none;
        min-width: 0;

        &.nested {
          opacity: 0.72;
          padding-left: 0.75rem;
        }
      }

      > ol > li > a {
        display: block;
        color: var(--text-color-secondary);
        text-decoration: none;
        font-size: 0.8rem;
        line-height: 1.46;
        text-wrap: wrap;
        overflow-wrap: anywhere;
        word-break: break-word;
        padding: 0.15rem 0;
        position: relative;
        transition:
          color 0.18s ease,
          transform 0.18s ease;

        &::before {
          content: "";
          position: absolute;
          left: -1.4rem;
          top: 50%;
          width: 0.5rem;
          height: 1px;
          background: transparent;
          transform: translateY(-50%);
          transition:
            background 0.18s ease,
            width 0.18s ease;
        }

        &.is-active {
          color: var(--text-color);
        }

        &.is-active::before {
          width: 0.8rem;
          background: color-mix(
            in srgb,
            var(--text-color) 34%,
            var(--border-color) 66%
          );
        }

        &:hover {
          color: var(--text-color);
          text-decoration: none;
          transform: translateX(0.08rem);
        }
      }
    }

    @media (max-width: 1080px) {
      .blog-detail-shell {
        max-width: 72ch;
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .blog-detail-toc-wrap {
        order: -1;
        margin: 0 0 1.8rem;
      }

      .blog-detail-toc-panel {
        width: 100%;
      }

      .blog-detail-toc {
        position: static;
        padding: 1rem 1rem 1.05rem;
        border-left: none;
        border: 1px solid
          color-mix(in srgb, var(--text-color) 8%, var(--border-color) 92%);
        border-radius: 0.9rem;
        background: color-mix(in srgb, var(--bg-color) 96%, white 4%);
        max-height: none;
        overflow: visible;

        &.is-fixed {
          position: static;
        }

        .toc-top {
          margin-bottom: 0.85rem;
        }

        > ol {
          display: grid;
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 0.25rem 1rem;
        }

        > ol > li {
          &.nested {
            padding-left: 0.6rem;
          }
        }

        > ol > li > a {
          min-height: 2.5rem;
          padding: 0.45rem 0 0.45rem 0.65rem;
          font-size: 0.9rem;
          line-height: 1.45;

          &::before {
            left: 0;
            width: 0.35rem;
          }

          &.is-active::before {
            width: 0.55rem;
          }
        }
      }
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      margin-top: 2rem;
      margin-bottom: 0.78rem;
      line-height: 1.15;
      letter-spacing: -0.03em;
    }

    h2,
    h3 {
      font-family: Iowan Old Style, Palatino Linotype, Book Antiqua, Georgia,
        serif;
    }

    h2 {
      margin-top: 2.7rem;
      margin-bottom: 0.95rem;
      font-size: clamp(1.55rem, 2.1vw, 2rem);
      line-height: 1.08;
    }

    h3 {
      margin-top: 1.9rem;
      margin-bottom: 0.7rem;
      font-size: clamp(1.18rem, 1.45vw, 1.4rem);
      line-height: 1.16;
    }

    p {
      max-width: 68ch;
      margin: 1rem 0;
      line-height: 1.88;
    }

    h2 + p,
    h3 + p,
    h4 + p {
      margin-top: 0.2rem;
    }

    blockquote {
      max-width: 64ch;
      margin: 1.9rem 0;
      padding: 0.2rem 0 0.2rem 1.15rem;
      position: relative;
      color: var(--text-color-secondary);
      font-size: 0.98rem;
      line-height: 1.82;

      &::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.2rem;
        bottom: 0.2rem;
        width: 1px;
        background: color-mix(
          in srgb,
          var(--text-color) 14%,
          var(--border-color) 86%
        );
      }
    }

    ul,
    ol {
      max-width: 66ch;
      margin: 1.1rem 0 1.35rem 1.1rem;
      padding-left: 1.1rem;
    }

    li {
      margin: 0.4rem 0;
      line-height: 1.78;
    }

    :not(pre) > code {
      background-color: var(--code-bg-color);
      padding: 0.14rem 0.38rem;
      border-radius: 0.24rem;
      font-size: 0.92em;
      color: color-mix(in srgb, var(--text-color) 86%, var(--primary-color) 14%);
      border: 1px solid color-mix(in srgb, var(--text-color) 8%, transparent);
    }

    pre {
      margin: 1.95rem 0;
      padding: 0.2rem 0;
      border-radius: 0.65rem;
      box-shadow: none;
      border: 1px solid color-mix(in srgb, var(--text-color) 8%, var(--border-color) 92%);
      overflow-x: auto;
    }

    pre code {
      display: block;
      background: transparent;
      padding: 0;
      border: none;
      color: inherit;
    }

    .expressive-code {
      margin: 1.95rem 0;

      .frame {
        box-shadow: none;
      }
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      margin: 1.95rem 0;
      background: var(--bg-color);
      border-radius: 0.45rem;
      box-shadow: none;
      border: 1px solid color-mix(in srgb, var(--text-color) 8%, var(--border-color) 92%);
      overflow: hidden;

      th {
        background: var(--blog-table-header-bg-color);
        color: var(--text-color);
        font-weight: 700;
        font-size: 0.96rem;
        padding: 0.8rem 0.75rem;
        border-bottom: 1px solid var(--border-color);
      }

      tr {
        &:nth-child(even) {
          background: var(--bg-color);
        }

        &:hover {
          background: var(--table-hover-color);
          transition: background 0.2s;
        }
      }

      th,
      td {
        border: none;
        padding: 0.8rem 0.75rem;
        text-align: left;
      }

      td {
        font-size: 0.96rem;
        color: var(--text-color);
      }
    }

    hr {
      border: none;
      border-top: 1px solid color-mix(in srgb, var(--text-color) 8%, var(--border-color) 92%);
      height: 0;
      margin: 2.15rem auto;
    }

    a {
      color: color-mix(in srgb, var(--text-color) 82%, var(--primary-color) 18%);
      text-decoration: none;
      text-decoration-thickness: 1px;
      text-underline-offset: 0.14em;

      &:hover {
        text-decoration: underline;
        color: var(--text-color);
      }
    }

    img {
      max-width: 100%;
      height: auto;
      display: block;
      margin: 2rem auto;
      padding: 0;
      border-radius: 0.35rem;
      box-shadow: 0 10px 28px rgba(60, 60, 60, 0.06);
    }

    @media (max-width: 720px) {
      .blog-detail-header {
        margin-bottom: 1.8rem;
        padding-bottom: 1.35rem;
        gap: 0.75rem;

        .title {
          max-width: none;
          font-size: 2.4rem;
        }

        .description {
          max-width: none;
          font-size: 0.96rem;
          line-height: 1.78;
        }
      }

      .blog-detail-content {
        max-width: none;
      }

      .blog-detail-shell {
        max-width: none;
      }

      .blog-detail-toc-wrap {
        margin: 0 0 1.45rem;
      }

      .blog-detail-toc-panel {
        border: 1px solid
          color-mix(in srgb, var(--text-color) 8%, var(--border-color) 92%);
        border-radius: 0.8rem;
        background: color-mix(in srgb, var(--bg-color) 96%, white 4%);
        overflow: hidden;

        &[open] {
          .blog-detail-toc-summary {
            border-bottom: 1px solid
              color-mix(in srgb, var(--text-color) 8%, var(--border-color) 92%);
          }
        }
      }

      .blog-detail-toc-summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.8rem;
        padding: 0.95rem 0.9rem;
        min-height: 3rem;

        .summary-label {
          color: var(--text-color);
          font-size: 0.74rem;
          font-weight: 700;
          letter-spacing: 0.18em;
          text-transform: uppercase;
        }

        .summary-meta {
          color: var(--text-color-secondary);
          font-size: 0.74rem;
          font-weight: 600;
          letter-spacing: 0.08em;
          text-transform: uppercase;
        }
      }

      .blog-detail-toc {
        margin-top: 0;
        padding: 0.9rem 0.9rem 0.95rem;
        border: none;
        border-radius: 0.8rem;
        background: transparent;
        max-height: none;
        overflow: visible;

        > ol {
          grid-template-columns: 1fr;
          gap: 0.1rem;
          max-height: min(48vh, 22rem);
          overflow-y: auto;
          padding-right: 0.15rem;
        }

        > ol > li > a {
          min-height: 2.75rem;
          font-size: 0.95rem;
          padding: 0.5rem 0 0.5rem 0.7rem;
        }

        .toc-label,
        .toc-back-top {
          font-size: 0.72rem;
        }
      }

      .blog-detail-toc > ol > li {
        &.nested {
          padding-left: 0.35rem;
        }
      }

      .blog-detail-toc-panel:not([open]) {
        .blog-detail-toc {
          display: none;
        }
      }

      p {
        max-width: none;
        line-height: 1.82;
      }

      h2 {
        margin-top: 2.25rem;
        font-size: 1.52rem;
      }

      h3 {
        margin-top: 1.7rem;
        font-size: 1.18rem;
      }

      blockquote {
        max-width: none;
      }

      ul,
      ol {
        max-width: none;
      }
    }

    @media (max-width: 420px) {
      .blog-detail-toc-summary {
        padding-inline: 0.82rem;
      }

      .blog-detail-toc {
        padding-inline: 0.82rem;

        .toc-top {
          gap: 0.6rem;
        }

        > ol > li > a {
          font-size: 0.92rem;
          line-height: 1.4;
        }
      }
    }
  }
</style>
