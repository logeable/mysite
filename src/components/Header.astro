---
import CONFIG from "../config";

const { pathname } = Astro.url;

// Normalize the current path by removing trailing slashes (except for root "/")
const currentPath = pathname.replace(/\/$/, "") || "/";

// Check if a given path is active
const isActive = (path: string) => {
  if (currentPath === path) return true;

  const [currentRoot] = currentPath.split("/").filter(Boolean);
  const [pathRoot] = path.split("/").filter(Boolean);

  return currentRoot === pathRoot;
};

const navigations = [
  { name: "Blogs", path: "/blogs" },
  { name: "Tags", path: "/tags" },
  { name: "Projects", path: "/projects" },
  { name: "About", path: "/about" },
];
---

<header>
  <h1 class="logo"><a href="/">{CONFIG.author}</a></h1>
  <button
    class="burger"
    id="burger-btn"
    aria-label="菜单"
    aria-expanded="false"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>
  <nav>
    <ul id="nav-menu">
      {
        navigations.map((nav) => (
          <li>
            <a href={nav.path} class:list={{ active: isActive(nav.path) }}>
              {nav.name}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style lang="scss">
  header {
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid color-mix(in srgb, var(--text-color) 10%, var(--border-color) 90%);
    position: relative;
    background: transparent;
    transition:
      background 0.2s,
      border-bottom-color 0.2s;
    margin: 0 0.2rem;
  }

  .logo a {
    text-decoration: none;
    color: var(--text-color);
    font-weight: 800;
    font-size: clamp(2rem, 3vw, 3rem);
    letter-spacing: -0.06em;
    line-height: 0.95;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 20;
  }
  .burger span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--text-color);
    border-radius: 999px;
    transition: background 0.2s;
  }

  nav ul {
    display: flex;
    list-style: none;
    gap: 1.4rem;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    background: transparent;
  }

  nav a {
    text-decoration: none;
    color: color-mix(in srgb, var(--text-color) 88%, var(--text-color-secondary) 12%);
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.1rem 0;
    border-radius: 0;
    position: relative;
    transition:
      color 0.2s,
      opacity 0.2s;
  }

  nav a:hover {
    color: var(--text-color);
  }
  nav a.active {
    color: var(--text-color);
  }

  nav a.active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.35rem;
    height: 1px;
    background: color-mix(in srgb, var(--text-color) 28%, var(--border-color) 72%);
  }

  @media (max-width: 600px) {
    .burger {
      display: flex;
      margin-left: auto;
    }
    nav ul {
      position: absolute;
      margin: 0 1rem;
      top: 72px;
      left: 0;
      right: 0;
      background: color-mix(in srgb, var(--bg-color) 96%, var(--text-color) 4%);
      flex-direction: column;
      gap: 0;
      border: 1px solid color-mix(in srgb, var(--text-color) 10%, var(--border-color) 90%);
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.12);
      padding: 0.45rem 0;
      display: none;
      z-index: 10;
      transition: all 0.25s;
    }
    nav ul.open {
      display: flex;
    }
    nav li {
      width: 100%;
      text-align: center;
      padding: 0.55rem 0;
    }
    nav a {
      font-size: 0.9rem;
      padding: 0.1rem 0;
    }
    nav a.active::after {
      left: 50%;
      right: auto;
      width: 1.5rem;
      transform: translateX(-50%);
      bottom: -0.25rem;
    }
  }

  @media (prefers-color-scheme: dark) {
    header {
      background: transparent;
      border-bottom-color: color-mix(
        in srgb,
        var(--text-color) 12%,
        var(--border-color) 88%
      );
    }
    .logo a {
      color: var(--text-color);
    }
    .burger span {
      background: var(--text-color);
    }
    nav ul {
      background: transparent;
    }
    nav a {
      color: color-mix(in srgb, var(--text-color) 86%, var(--text-color-secondary) 14%);
    }
    nav a:hover,
    nav a.active {
      color: var(--text-color);
    }
  }
</style>

<script is:inline>
  const burger = document.getElementById("burger-btn");
  const menu = document.getElementById("nav-menu");
  burger.addEventListener("click", () => {
    const expanded = burger.getAttribute("aria-expanded") === "true";
    burger.setAttribute("aria-expanded", !expanded);
    menu.classList.toggle("open");
  });
  // 点击菜单项后自动收起
  menu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      burger.setAttribute("aria-expanded", false);
      menu.classList.remove("open");
    });
  });
</script>
