---
import CONFIG from "../config";

const { pathname } = Astro.url;

// Normalize the current path by removing trailing slashes (except for root "/")
const currentPath = pathname.replace(/\/$/, "") || "/";

// Check if a given path is active
const isActive = (path: string) => {
  if (currentPath === path) return true;

  const [currentRoot] = currentPath.split("/").filter(Boolean);
  const [pathRoot] = path.split("/").filter(Boolean);

  return currentRoot === pathRoot;
};

const navigations = [
  { name: "Blogs", path: "/blogs" },
  { name: "Tags", path: "/tags" },
  { name: "Projects", path: "/projects" },
  { name: "About", path: "/about" },
];
---

<header>
  <h1 class="logo"><a href="/">{CONFIG.author}</a></h1>
  <button
    class="burger"
    id="burger-btn"
    aria-label="菜单"
    aria-expanded="false"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>
  <nav>
    <ul id="nav-menu">
      {
        navigations.map((nav) => (
          <li>
            <a href={nav.path} class:list={{ active: isActive(nav.path) }}>
              {nav.name}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  <button class="nav-backdrop" id="nav-backdrop" aria-hidden="true" tabindex="-1"></button>
</header>

<style lang="scss">
  header {
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid color-mix(in srgb, var(--text-color) 10%, var(--border-color) 90%);
    position: relative;
    background: transparent;
    transition:
      background 0.2s,
      border-bottom-color 0.2s;
    margin: 0 0.2rem;
    z-index: 30;
  }

  .logo a {
    text-decoration: none;
    color: var(--text-color);
    font-weight: 800;
    font-size: clamp(2rem, 3vw, 3rem);
    letter-spacing: -0.06em;
    line-height: 0.95;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 44px;
    height: 44px;
    padding: 0;
    background: color-mix(in srgb, var(--bg-color) 97%, var(--text-color) 3%);
    border: 1px solid color-mix(in srgb, var(--text-color) 8%, var(--border-color) 92%);
    border-radius: 999px;
    cursor: pointer;
    z-index: 20;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .burger span {
    display: block;
    height: 2px;
    width: 18px;
    margin: 0 auto;
    background: var(--text-color);
    border-radius: 999px;
    transform-origin: center;
    transition:
      background 0.2s ease,
      transform 0.22s ease,
      opacity 0.18s ease;
  }

  .burger:hover {
    background: color-mix(in srgb, var(--bg-color) 94%, var(--text-color) 6%);
    border-color: color-mix(in srgb, var(--text-color) 11%, var(--border-color) 89%);
  }

  .burger[aria-expanded="true"] {
    background: color-mix(in srgb, var(--bg-color) 94%, var(--text-color) 6%);
    border-color: color-mix(in srgb, var(--text-color) 12%, var(--border-color) 88%);
  }

  .burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .burger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  nav ul {
    display: flex;
    list-style: none;
    gap: 1.4rem;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    background: transparent;
  }

  nav a {
    text-decoration: none;
    color: color-mix(in srgb, var(--text-color) 88%, var(--text-color-secondary) 12%);
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.1rem 0;
    border-radius: 0;
    position: relative;
    transition:
      color 0.2s,
      opacity 0.2s;
  }

  nav a:hover {
    color: var(--text-color);
  }
  nav a.active {
    color: var(--text-color);
  }

  nav a.active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.35rem;
    height: 1px;
    background: color-mix(in srgb, var(--text-color) 28%, var(--border-color) 72%);
  }

  .nav-backdrop {
    display: none;
  }

  @media (max-width: 600px) {
    header {
      isolation: isolate;
    }

    .burger {
      display: flex;
      margin-left: auto;
    }

    nav {
      position: static;
    }

    nav ul {
      position: fixed;
      top: 0.75rem;
      right: 0.5rem;
      left: auto;
      width: min(18rem, calc(100vw - 1rem));
      margin: 0;
      background: color-mix(in srgb, var(--bg-color) 98%, var(--text-color) 2%);
      flex-direction: column;
      gap: 0.1rem;
      border: 1px solid color-mix(in srgb, var(--text-color) 8%, var(--border-color) 92%);
      border-radius: 1.15rem;
      box-shadow: 0 18px 44px rgba(17, 17, 17, 0.08);
      padding: 4.35rem 0.45rem 0.45rem;
      display: flex;
      z-index: 18;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(-0.35rem) scale(0.985);
      transition:
        opacity 0.22s ease,
        transform 0.22s ease,
        visibility 0.22s ease;
    }

    nav ul.open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateY(0) scale(1);
    }

    nav li {
      width: 100%;
      text-align: left;
      padding: 0;
    }

    nav a {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      min-height: 2.95rem;
      padding: 0.75rem 0.9rem;
      font-size: 0.98rem;
      letter-spacing: 0.01em;
      border-radius: 0.8rem;
      transition:
        color 0.2s ease,
        background 0.2s ease;
    }

    nav a:hover {
      background: color-mix(in srgb, var(--bg-color) 95%, var(--text-color) 5%);
    }

    nav a.active {
      background: color-mix(in srgb, var(--bg-color) 95%, var(--text-color) 5%);
    }

    nav a.active::after {
      left: 0.9rem;
      right: 0.9rem;
      width: auto;
      transform: none;
      bottom: 0.45rem;
      background: color-mix(in srgb, var(--text-color) 20%, var(--border-color) 80%);
    }

    .nav-backdrop {
      position: fixed;
      inset: 0;
      display: block;
      border: 0;
      padding: 0;
      background: color-mix(in srgb, var(--bg-color) 54%, transparent);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.22s ease;
      z-index: 12;
    }

    .nav-backdrop.open {
      opacity: 1;
      pointer-events: auto;
    }
  }

  @media (prefers-color-scheme: dark) {
    header {
      background: transparent;
      border-bottom-color: color-mix(
        in srgb,
        var(--text-color) 12%,
        var(--border-color) 88%
      );
    }
    .logo a {
      color: var(--text-color);
    }
    .burger span {
      background: var(--text-color);
    }
    nav ul {
      background: transparent;
    }
    nav a {
      color: color-mix(in srgb, var(--text-color) 86%, var(--text-color-secondary) 14%);
    }
    nav a:hover,
    nav a.active {
      color: var(--text-color);
    }
  }
</style>

<script is:inline>
  const burger = document.getElementById("burger-btn");
  const menu = document.getElementById("nav-menu");
  const backdrop = document.getElementById("nav-backdrop");

  if (burger && menu && backdrop) {
    const closeMenu = () => {
      burger.setAttribute("aria-expanded", "false");
      menu.classList.remove("open");
      backdrop.classList.remove("open");
    };

    const openMenu = () => {
      burger.setAttribute("aria-expanded", "true");
      menu.classList.add("open");
      backdrop.classList.add("open");
    };

    burger.addEventListener("click", () => {
      const expanded = burger.getAttribute("aria-expanded") === "true";
      if (expanded) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    backdrop.addEventListener("click", closeMenu);

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeMenu();
      }
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 600) {
        closeMenu();
      }
    });
  }
</script>
